{
  "name": "kodeworks",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "web",
    "studio"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "studio:deploy": "turbo run deploy",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "studio:validate:development": "npm run studio:validate:development -w studio",
    "studio:validate:production": "npm run studio:validate:production -w studio"
  },
  "devDependencies": {
    "prettier": "^2.5.1",
    "turbo": "^2.8.13"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@9.4.0"
}
